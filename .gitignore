# =====================================================================
#  APS Group website — Git ignore
#  Excludes references, source material, docs, and build/runtime junk.
#  (db.sqlite3 and media/ ARE kept — they hold the live CMS content.)
# =====================================================================

# ---- References, sources & documentation (not needed in the repo) ----
*.md
/References/

# ---- Python bytecode / packaging ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.Python

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/
.python-version

# ---- Django / runtime artifacts ----
*.log
# gettext template (regenerated by makemessages)
*.pot
local_settings.py
.env
.env.*
# collectstatic output (STATIC_ROOT) — rebuilt on deploy
/staticfiles/
# sqlite temp journal (the db itself is kept)
db.sqlite3-journal

# ---- Editor / IDE / OS ----
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db
desktop.ini

# ---- Scratch / temporary working files ----
scratch_*
*.tmp
*.bak
